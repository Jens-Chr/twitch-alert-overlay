# Public host Traefik should route for this overlay.
ALERT_OVERLAY_HOST=alerts.example.com

# Optional admin password for /admin/alerts. Empty means unprotected.
ADMIN_PASSWORD=

# Optional maximum upload size in bytes. Default: 200 MiB.
MAX_UPLOAD_BYTES=209715200

# Traefik settings. Adjust to your Traefik installation.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# External Docker network shared with n8n and Traefik.
N8N_NETWORK=n8n-network
